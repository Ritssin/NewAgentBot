# Copy to .env and fill in. Never commit .env.
# With config/settings.json (web UI), these keys still load from .env only.

# --- API keys (never put these in settings JSON) ---
OPENAI_API_KEY=sk-...
# Required only when llm_provider is claude (or set in config/settings.json UI + this key)
# ANTHROPIC_API_KEY=sk-ant-...

# --- Used when config/settings.json is missing (CLI / env-only mode) ---
# USE_OLLAMA=1
# LLM_BACKEND=openai|ollama|claude
# LLM_PROVIDER=openai|ollama|claude
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
# RSS_FEEDS=https://example.com/feed.xml,https://other.com/rss
# TOP_N_STORIES=8
# OUTPUT_HTML=output/briefing.html
# SYSTEM_PROMPT=...
# USER_PROMPT_TEMPLATE=... use {stories} for the headline block ...

# Optional: custom path to settings JSON
# NEWS_AGENT_SETTINGS=config/settings.json

# Web server (python web_app.py)
# FLASK_SECRET_KEY=change-me
# PORT=5000
