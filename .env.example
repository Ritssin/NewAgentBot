# Copy to .env and fill in. Never commit .env.

# --- LLM backend: OpenAI (cloud) or Ollama (local) ---
# Option A — Ollama (local): install https://ollama.com then `ollama pull llama3.2`
USE_OLLAMA=1
# OPENAI_BASE_URL defaults to http://localhost:11434/v1 when using Ollama
# OPENAI_API_KEY defaults to "ollama" (required by SDK; Ollama ignores it)
OPENAI_MODEL=llama3.2

# Option B — OpenAI (cloud): set USE_OLLAMA=0 or remove it, then:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# (OPENAI_BASE_URL only if you use a non-default endpoint)

# Optional explicit switch instead of USE_OLLAMA:
# LLM_BACKEND=ollama
# LLM_BACKEND=openai

# Where to write the HTML report (relative or absolute path)
OUTPUT_HTML=output/briefing.html

# Optional feeds: comma-separated RSS URLs (otherwise defaults in news_agent.py)
# RSS_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml,https://example.com/feed.xml

# How many newest items to send to the model
# TOP_N_STORIES=8
